{
  "version": 2,
  "name": "llm-agent-architecture-lab",

  "builds": [
    {
      "src": "api/claude.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],

  "routes": [
    {
      "src": "/api/claude",
      "dest": "/api/claude.js",
      "methods": ["POST", "OPTIONS"]
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ],

  "functions": {
    "api/claude.js": {
      "maxDuration": 60
    }
  },

  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" }
      ]
    }
  ]
}
