{
  "version": 2,
  "name": "module-design-flow",
  "outputDirectory": "public",

  "functions": {
    "api/mistral.js": {
      "maxDuration": 60
    }
  },

  "rewrites": [
    { "source": "/", "destination": "/part2-developer-discipline-agent.html" }
  ],

  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" }
      ]
    }
  ]
}
